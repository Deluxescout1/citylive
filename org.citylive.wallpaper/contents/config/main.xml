<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>
  <group name="General">
    <entry name="scene" type="String">
      <default>neon</default>
    </entry>
    <!-- Total width (logical px) of the whole multi-monitor desktop. All screens
         share this so the city is one continuous world. -->
    <entry name="worldW" type="Int">
      <default>6808</default>
    </entry>
    <entry name="quality" type="String">
      <default></default>
    </entry>
    <entry name="showStatus" type="Bool">
      <default>true</default>
    </entry>
    <entry name="chronicleEnabled" type="Bool">
      <default>true</default>
    </entry>
    <!-- Desktop notifications for major city events (elections, big disasters, takeovers, eclipses). -->
    <entry name="notifyEvents" type="Bool">
      <default>true</default>
    </entry>
    <!-- This screen's left edge in the global desktop (logical px). -1 = auto
         (read Screen.virtualX). Set explicitly only if auto-detect is wrong. -->
    <entry name="worldX" type="Int">
      <default>-1</default>
    </entry>
    <!-- Height (logical px) of the bottom panel/taskbar to keep the road clear of.
         -1 = auto (read Plasma's availableScreenRect; on Wayland this is often 0
         because panels are hidden from wallpaper clients). Set to your panel height
         only if the road is being clipped by a tall taskbar. -->
    <entry name="taskbarPx" type="Int">
      <default>-1</default>
    </entry>
    <!-- User location override (city/ZIP/address lookup in the config UI). 999 = unset
         sentinel: falls back to config.local.json (install.sh-generated) or the engine's
         built-in default (Norwich, CT). Real coordinates are always within [-90,90]/
         [-180,180], so 999 can never collide with a genuine value. -->
    <entry name="latitude" type="Double">
      <default>999</default>
    </entry>
    <entry name="longitude" type="Double">
      <default>999</default>
    </entry>
    <entry name="locationName" type="String">
      <default></default>
    </entry>
    <!-- Pinned apocalypse: "auto" (a different fate each life, the engine's own default)
         or one of the 12 exact engine death names (DEATHS in js/city.js, plus the
         picker-only kaijuwar/pollution fates). -->
    <entry name="finale" type="String">
      <default>auto</default>
    </entry>
    <!-- "End the world now" / "Start a fresh world" request from the config dialog: the
         ms timestamp of the click. 0 = never requested. Applied once per boot alongside
         worldRestartMode; the user re-clicking sets a new timestamp to fire again. -->
    <entry name="worldRestartAt" type="Double">
      <default>0</default>
    </entry>
    <!-- "apoc" = the pinned/chosen finale plays out now, then rebirth. "fresh" = skip
         straight to a reborn wilderness. -->
    <entry name="worldRestartMode" type="String">
      <default>apoc</default>
    </entry>
    <!-- Live flights: show REAL aircraft near your location (a free ADS-B feed, polled ~90s).
         On by default. Turn off if you'd rather the sky held only the decorative jets (it calls
         a public API with your area's coordinates). -->
    <entry name="flights" type="Bool">
      <default>true</default>
    </entry>
    <entry name="bills" type="Bool">
      <default>false</default>
    </entry>
  </group>
</kcfg>
